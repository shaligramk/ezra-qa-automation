# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored — never commit credentials.

# Base URL for the member-facing booking portal.
BASE_URL=https://myezra-staging.ezra.com

# Test user credentials. Members can be created freely on the member portal,
# so the suite expects you to provide your own.
USER_EMAIL=your-test-member@example.com
USER_PWD=replace-me

# Optional: override default test data
# TEST_DOB=1990-01-15
# TEST_SEX_AT_BIRTH=Male
# TEST_ZIP=10001

# Optional: override the booking entry path if it isn't at /
# BOOKING_PATH=/book
